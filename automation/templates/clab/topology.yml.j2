name: evpn-lab-auto

topology:
  nodes:
    spine1:
      kind: linux
      image: quay.io/frrouting/frr:10.1.1
      binds:
        - ./configs/spine1/daemons:/etc/frr/daemons
        - ./configs/spine1/frr.conf:/etc/frr/frr.conf

    spine2:
      kind: linux
      image: quay.io/frrouting/frr:10.1.1
      binds:
        - ./configs/spine2/daemons:/etc/frr/daemons
        - ./configs/spine2/frr.conf:/etc/frr/frr.conf

    leaf1:
      kind: linux
      image: quay.io/frrouting/frr:10.1.1
      binds:
        - ./configs/leaf1/daemons:/etc/frr/daemons
        - ./configs/leaf1/frr.conf:/etc/frr/frr.conf
        - ./configs/leaf1/startup.sh:/startup.sh
      exec:
        - /startup.sh

    leaf2:
      kind: linux
      image: quay.io/frrouting/frr:10.1.1
      binds:
        - ./configs/leaf2/daemons:/etc/frr/daemons
        - ./configs/leaf2/frr.conf:/etc/frr/frr.conf
        - ./configs/leaf2/startup.sh:/startup.sh
      exec:
        - /startup.sh

    leaf3:
      kind: linux
      image: quay.io/frrouting/frr:10.1.1
      binds:
        - ./configs/leaf3/daemons:/etc/frr/daemons
        - ./configs/leaf3/frr.conf:/etc/frr/frr.conf
        - ./configs/leaf3/startup.sh:/startup.sh
      exec:
        - /startup.sh

    client1:
      kind: linux
      image: alpine:latest
      exec:
        - ip addr add 192.168.10.11/24 dev eth1
        - ip link set eth1 up

    client2:
      kind: linux
      image: alpine:latest
      exec:
        - ip addr add 192.168.10.12/24 dev eth1
        - ip link set eth1 up

    client3:
      kind: linux
      image: alpine:latest
      exec:
        - ip addr add 192.168.10.13/24 dev eth1
        - ip link set eth1 up

  links:
    - endpoints: ["leaf1:eth1", "spine1:eth1"]
    - endpoints: ["leaf1:eth2", "spine2:eth1"]
    - endpoints: ["leaf2:eth1", "spine1:eth2"]
    - endpoints: ["leaf2:eth2", "spine2:eth2"]
    - endpoints: ["leaf3:eth1", "spine1:eth3"]
    - endpoints: ["leaf3:eth2", "spine2:eth3"]
    - endpoints: ["client1:eth1", "leaf1:eth10"]
    - endpoints: ["client2:eth1", "leaf2:eth10"]
    - endpoints: ["client3:eth1", "leaf3:eth10"]
